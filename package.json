{
  "name": "ahj-media",
  "version": "1.0.0",
  "description": "Timeline with geolocation - Educational project",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:clear": "jest --clearCache",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "coverage": "jest --coverage",
    "deploy": "gh-pages -d dist -b gh-pages",
    "predeploy": "npm run build",
    "validate": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "timeline",
    "geolocation",
    "webpack",
    "jest",
    "media",
    "eslint",
    "babel"
  ],
  "author": "lokilaufer",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/lokilaufer/ahj-media.git"
  },
  "homepage": "https://lokilaufer.github.io/ahj-media",
  "bugs": {
    "url": "https://github.com/lokilaufer/ahj-media/issues"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "eslint": "^9.21.0",
    "gh-pages": "^6.3.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.2",
    "style-loader": "^4.0.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    },
    "transformIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "src/js/**/*.js",
      "!src/index.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/__tests__/**/*.spec.js"
    ],
    "setupFilesAfterEnv": []
  }
}