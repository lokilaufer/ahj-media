{
  "name": "ahj-media",
  "version": "1.0.0",
  "description": "Timeline with geolocation - Educational project",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:clear": "jest --clearCache",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:ci": "eslint src/ --max-warnings 0",
    "coverage": "jest --coverage",
    "deploy": "gh-pages -d dist -b gh-pages",
    "prepare": "husky install",
    "predeploy": "npm run build",
    "validate": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "timeline",
    "geolocation",
    "webpack",
    "jest",
    "media",
    "eslint",
    "babel"
  ],
  "author": "lokilaufer",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/lokilaufer/ahj-media.git"
  },
  "homepage": "https://lokilaufer.github.io/ahj-media",
  "bugs": {
    "url": "https://github.com/lokilaufer/ahj-media/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.51.0",
    "gh-pages": "^6.0.0",
    "html-loader": "^4.2.0",
    "html-webpack-plugin": "^5.5.3",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.0.2",
    "mini-css-extract-plugin": "^2.7.6",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    },
    "transformIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "src/js/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "src/js/geolocation.js": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    },
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/__tests__/**/*.spec.js"
    ],
    "setupFilesAfterEnv": []
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "jest --findRelatedTests --passWithNoTests"
    ],
    "*.{css,html,json}": [
      "prettier --write"
    ]
  }
}